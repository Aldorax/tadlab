generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id               String   @id @default(cuid())
  title            String
  date             String
  location         String
  shortDescription String
  fullDescription  String
  image            String
  link             String
  tags             String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PageContent {
  id        String   @id @default(cuid())
  pageId    String   @unique
  heroTitle String?
  heroSub   String?
  heroImage String?
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  excerpt         String
  content         String
  image           String?
  author          String?
  metaTitle       String?
  metaDescription String?
  published       Boolean  @default(false)
  tags            String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Role-Based Access Control ──────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         AdminRole @default(ADMIN)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Who invited this user (null for the initial super admin)
  invitedById  String?
  invitedBy    AdminUser?  @relation("InvitedUsers", fields: [invitedById], references: [id])
  invitedUsers AdminUser[] @relation("InvitedUsers")

  sessions        AdminSession[]
  sentInvites     AdminInvite[]
  submittedChanges PendingChange[] @relation("SubmittedChanges")
  reviewedChanges  PendingChange[] @relation("ReviewedChanges")
}

model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminInvite {
  id        String    @id @default(cuid())
  email     String
  role      AdminRole @default(ADMIN)
  token     String    @unique
  expiresAt DateTime
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())

  invitedById String
  invitedBy   AdminUser @relation(fields: [invitedById], references: [id])
}

enum ChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChangeType {
  CREATE
  UPDATE
  DELETE
}

model PendingChange {
  id         String       @id @default(cuid())
  type       ChangeType
  resource   String       // "event", "project", "blog", "content"
  resourceId String?      // ID of existing resource (for UPDATE/DELETE)
  payload    Json         // Full data payload
  status     ChangeStatus @default(PENDING)
  note       String?      // Optional reviewer note
  createdAt  DateTime     @default(now())

  submittedById String
  submittedBy   AdminUser @relation("SubmittedChanges", fields: [submittedById], references: [id])

  reviewedById String?
  reviewedBy   AdminUser? @relation("ReviewedChanges", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
}
