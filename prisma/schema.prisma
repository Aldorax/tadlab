generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id               String   @id @default(cuid())
  title            String
  date             String
  location         String
  shortDescription String
  fullDescription  String
  image            String
  link             String
  tags             String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PageContent {
  id        String   @id @default(cuid())
  pageId    String   @unique
  heroTitle String?
  heroSub   String?
  heroImage String?
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
